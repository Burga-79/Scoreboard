{
  "name": "cometbay-scoreboard",
  "version": "1.0.0",
  "description": "Comet Bay Bowling Club Scoreboard System",
  "main": "main.js",
  "author": "Comet Bay Bowling Club",

  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win"
  },

  "dependencies": {
    "express": "^4.18.2",
    "multer": "1.4.5-lts.1"
  },

  "devDependencies": {
    "electron": "28.0.0",
    "electron-builder": "24.6.0"
  },

  "build": {
    "appId": "cometbay.scoreboard",
    "productName": "Start Scoreboard",

    "directories": {
      "output": "dist"
    },

    "files": [
      "main.js",
      "server.js",
      "preload.js",
      "package.json",
      "admin/**/*",
      "display/**/*"
    ],

    "extraResources": [
      {
        "from": "images",
        "to": "images"
      }
    ],

    "asar": true,

    "win": {
      "target": [
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ]
    }
  }
}
